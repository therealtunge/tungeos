# Memory
megs: 2048

# Boot order (d = CD-ROM first)
boot: cdrom

# IDE hard disk


# IDE CD-ROM
ata0-slave: type=cdrom, path="myos.iso", status=inserted

# Serial output to console
com1: enabled=1, mode=stdio

# BIOS
romimage: file="/usr/share/bochs/BIOS-bochs-latest"  # adjust path to your bochs BIOS
vgaromimage: file="/usr/share/bochs/VGABIOS-lgpl-latest.bin"  # adjust path

# CPU and chipset
cpu: count=1, ips=100000000

